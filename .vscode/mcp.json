{
  "servers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "ucs-docs": {
      "command": ".venv/bin/python",
      "args": [
        "mcp/mcp-server.py"
      ],
      "type": "stdio"
    },
    "ucs-docs-mcp": {
      "type": "http",
      "url": "http://localhost:31310"
    }
  }
}
